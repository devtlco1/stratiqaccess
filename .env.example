# Supabase (required) — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres URL — only needed to run one-off migration scripts locally,
# not read by the running app. Use the pooler host (Project Settings > Database >
# Connection pooling), not the direct db.<ref>.supabase.co host (IPv6-only).
DATABASE_URL=

# Resend (required for contact-form email notifications) — https://resend.com
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=

# Full public URL of the deployed site (no trailing slash), e.g. https://stratiqaccess.com
NEXT_PUBLIC_SITE_URL=

# Analytics (optional) — scripts only load when these are set, so leave
# blank in local/dev environments. See README.md "Analytics" section.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# Email Center (required for /admin/email-center) — see docs/EMAIL_CENTER.md
# for full setup instructions. All of these are server-only; NONE of them may
# ever be prefixed NEXT_PUBLIC_ or referenced from client components.

# Supabase service-role key — Project Settings > API > service_role secret.
# Bypasses Row Level Security. Used ONLY by the webhook, cron, and unsubscribe
# route handlers (which have no admin browser session for RLS to check
# against). Never used by admin dashboard pages/Server Actions — those keep
# using the existing cookie-bound anon client in lib/supabase/server.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Hostinger Agentic Mail REST API — hPanel > Emails > partners@stratiqaccess.com
# > API tokens. Create a token restricted to this mailbox only, not the whole
# order, if your Hostinger plan supports scoping.
HOSTINGER_MAIL_API_TOKEN=
HOSTINGER_MAILBOX=partners@stratiqaccess.com
HOSTINGER_MAIL_API_BASE_URL=https://api.mail.hostinger.com

# Webhook secret returned once when the webhook is created via
# /admin/email-center/settings (or the Hostinger API directly). Verifies the
# `Authorization: Bearer <secret>` header on inbound POST /api/webhooks/hostinger-email
# requests. Separate secret from the API token above — rotating one never
# requires rotating the other.
HOSTINGER_WEBHOOK_SECRET=

# Shared secret for the Hostinger Cron Job that drives the bulk-send queue.
# Required as a Bearer token on POST /api/cron/email-queue. Generate with
# `openssl rand -hex 32`.
EMAIL_CRON_SECRET=

# HMAC secret used to sign one-click unsubscribe links (no login required to
# unsubscribe). Generate with `openssl rand -hex 32`. Rotating this
# invalidates all previously-sent unsubscribe links.
UNSUBSCRIBE_TOKEN_SECRET=
